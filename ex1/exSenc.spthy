theory ExerciseSymmetricEncryption
begin

builtins: symmetric-encryption 

rule KeyGen:
  [ Fr(~k) ]
  -->
  [ !LongTermKey($A, ~k) ]

rule SendMsg:
  [St_Alice($A), Fr(~msg), Fr(~k)]
  --[MessageWasSentBy($A, ~msg)
    ]->
  [St_Alice($A), OUT(senc(~msg,~k))]

rule Leak:
  [Fr(~k)]
  --[KeyLeaked(~k)
    ]->
  [Out(~k)]

lemma Secrecy:
  "All p m #t. MessageWasSentBy(p, m) @ #t ==> not Ex #x. K(m) @ #x"

end
